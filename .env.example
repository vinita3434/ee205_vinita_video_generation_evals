# --- Video generation (one prompt → 2 models: Kling + Sora) ---
# OpenAI Sora 2 (via LiteLLM)
OPENAI_API_KEY=sk-...

# fal.ai — Kling 2.6 Pro text-to-video
# Get key: https://fal.ai/dashboard/keys
FAL_KEY=...

# --- Judge: OpenRouter (Gemini) — you have OpenRouter credits ---
# Get key: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...

# Optional: default is google/gemini-2.0-flash-exp:free
# JUDGE_MODEL=google/gemini-2.0-flash-exp:free

# Optional: where to save generated videos (default: outputs/)
# OUTPUT_DIR=outputs
